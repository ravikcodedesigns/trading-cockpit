# ── Tradovate credentials ──────────────────────────────────────────────────────
# Create API credentials at https://trader.tradovate.com → Preferences → API
TRADOVATE_USERNAME=
TRADOVATE_PASSWORD=
TRADOVATE_APP_ID=Sample App
TRADOVATE_APP_VERSION=1.0
TRADOVATE_CID=
TRADOVATE_SECRET=

# "demo" = paper trading (demo.tradovateapi.com)  |  "live" = real money
TRADER_MODE=demo

# ── Risk limits ────────────────────────────────────────────────────────────────
# Hard-stop if daily realized+unrealized P&L drops below this (negative number, dollars)
TRADER_MAX_DAILY_LOSS=-500

# Maximum simultaneously open positions
TRADER_MAX_POSITIONS=1

# Contracts to trade: MNQ = Micro NQ ($2/pt), MES = Micro ES ($1.25/pt)
TRADER_CONTRACT_NQ=MNQ
TRADER_CONTRACT_ES=MES
TRADER_QTY=1

# ── Aggregator connection ──────────────────────────────────────────────────────
AGGREGATOR_WS=ws://127.0.0.1:8787/ws/cockpit

# ── Which signals to auto-trade (comma-separated rule IDs) ────────────────────
# Start with CF only. Add expl,absorption after paper-trading CF for 2 weeks.
TRADER_ENABLED_RULES=clean-impulse
