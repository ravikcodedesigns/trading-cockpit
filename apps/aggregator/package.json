{
  "name": "@trading/aggregator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc -p .",
    "typecheck": "tsc --noEmit",
    "score": "tsx scripts/score_outcomes.ts",
    "score:report": "tsx scripts/score_report.ts",
    "score:report:a": "tsx scripts/score_report.ts --strategy A",
    "score:report:b": "tsx scripts/score_report.ts --strategy B",
    "compare": "tsx scripts/compare_strategies.ts",
    "backfill:absorption": "tsx scripts/backfill_absorption.ts",
    "backfill:conviction": "tsx scripts/backfill_conviction.ts",
    "backfill:strategy-d": "tsx scripts/backfill_strategy_d.ts",
    "migrate:strategy-version": "tsx scripts/migrate_strategy_version.ts",
    "levels:add": "tsx scripts/levels_cli.ts",
    "context:set": "tsx scripts/context_set.ts set",
    "context:show": "tsx scripts/context_set.ts show",
    "context:resilience": "tsx scripts/context_set.ts resilience"
  },
  "dependencies": {
    "@fastify/websocket": "^10.0.1",
    "@trading/contracts": "workspace:*",
    "better-sqlite3": "^11.0.0",
    "dotenv": "^16.4.5",
    "fastify": "^4.27.0",
    "pino": "^9.1.0",
    "pino-pretty": "^11.1.0",
    "ws": "^8.17.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.10",
    "@types/node": "^20.12.12",
    "@types/ws": "^8.5.10",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5"
  }
}
