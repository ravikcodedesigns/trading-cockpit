<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.cockpit.reminder-flipshorts</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>/Users/ravikumarbasker/trading-cockpit/scripts/launchd/reminder.sh</string>
    <string>com.cockpit.reminder-flipshorts</string>
    <string>2026</string>
